# Bringing your own custom configuration
# Auth bootstrap applied to ALL workspaces on connect:
#   - If tmux isn't available on the remote, just run `ddtool auth login`.
#   - If tmux is available, refresh an "auth" window running the login command
#     and attach to the most recently used session (creating "scratch" only if
#     no session exists yet) instead of always landing in "scratch".
Match host "local-*,workspace-*,*.workspace.infra.dog"
    RequestTTY force
    RemoteCommand /bin/bash -c 'T=$(command -v tmux || echo /home/linuxbrew/.linuxbrew/bin/tmux); if [ ! -x "$T" ]; then ddtool auth login --datacenter us1.ddbuild.io; exec "$SHELL"; fi; $T list-sessions >/dev/null 2>&1 || $T new-session -ds scratch; S=$($T list-sessions -F "#{session_activity} #{session_name}" 2>/dev/null | sort -rn | head -n1 | cut -d" " -f2-); [ -z "$S" ] && S=scratch; $T kill-window -t "$S:auth" 2>/dev/null; $T new-window -t "$S" -n auth "ddtool auth login --datacenter us1.ddbuild.io; exec \$SHELL"; exec $T attach -t "$S"'
