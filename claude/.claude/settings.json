{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(perl:*)",
      "Bash(make:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "mcp__orgstore-local__query",
      "mcp__orgstore-local-test__query",
      "mcp__dwb-local__query",
      "mcp__github__get_pull_request",
      "mcp__github__get_pull_request_comments",
      "mcp__github__get_pull_request_reviews",
      "mcp__github__get_pull_request_files",
      "Bash(gh api:*)",
      "WebFetch(domain:github.com)",
      "Bash(go generate:*)",
      "Bash(go fmt:*)",
      "Bash(go list:*)",
      "Bash(go doc:*)",
      "Bash(go tool cover:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(bazel query:*)",
      "Bash(bazel build:*)",
      "Bash(bazel run:*)",
      "Bash(bazel test:*)",
      "Bash(bazel coverage:*)",
      "Bash(bzl query:*)",
      "Bash(bzl build:*)",
      "Bash(bzl run:*)",
      "Bash(bzl test:*)",
      "Bash(bzl coverage:*)",
      "Bash(poetry run python:*)",
      "Bash(mockgen:*)",
      "WebSearch"
    ],
    "deny": []
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "go-code-reviewer@datadog-claude-plugins": true,
    "python-code-reviewer@datadog-claude-plugins": true,
    "redblue@datadog-claude-plugins": true,
    "dd@datadog-claude-plugins": true,
    "osx-notifications@datadog-claude-plugins": true,
    "marketplace-auto-update@datadog-claude-plugins": true,
    "user-config@datadog-claude-plugins": true,
    "streaming-platform-operators@datadog-claude-plugins": true,
    "orgstore@datadog-claude-plugins": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "datadog": {
      "source": {
        "source": "github",
        "repo": "DataDog/claude-marketplace"
      }
    }
  },
  "forceLoginMethod": "console",
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754484704865
  }
}
